# Antigravity 運行狀態 (不納入版控，避免會話雜訊)
.gemini/
!.gemini/GEMINI.md
!.gemini/settings.json

# 參考資料
docs/reference/*

# 測試產物 (僅排除測試過程產生的暫存檔)
/tests/temp/
*.log

# 作業系統雜訊
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# IDE 設定
.vscode/
.idea/
*.suo
*.user

# Python / 環境隔離 (不納入版控)
**/.venv/
__pycache__/
*.pyc

temp_md_file/
tests/
